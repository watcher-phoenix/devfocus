{
  "extends": ["airbnb-base", "prettier"],
  "env": {
    "commonjs": true,
    "es6": true,
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "radix": 0,
    "no-underscore-dangle": 0,
    "no-unused-vars": 2,
    "no-unreachable": 2,
    "no-console": 0,
    "import/no-extraneous-dependencies": 0
  }
}
