# DevFocus Backend Configuration

# Generate a password hash: echo -n "yourpassword" | openssl dgst -sha256
# Leave empty in development to skip auth
DEVFOCUS_PASS_HASH=

# Database path (defaults to ./data/devfocus.sqlite3)
DEVFOCUS_DB_PATH=

# Server port (defaults to 3001)
DEVFOCUS_PORT=3001

# Frontend URL for CORS (defaults to http://localhost:5173)
DEVFOCUS_FRONTEND_URL=http://localhost:5173

NODE_ENV=development

# ── Microsoft Graph (Outlook calendar) ──────────────────────────────────────
# Azure app registration (Entra ID) for delegated calendar access.
# Delegated permission: Calendars.Read (+ offline_access). One-time consent via
# Settings → Outlook Calendar → Connect Microsoft.
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=
GRAPH_CLIENT_SECRET=
# Must EXACTLY match a redirect URI on the Azure app. Defaults to the prod URL.
# For local testing, register http://localhost:5173/api/integrations/calendar/callback
# and set this to that value.
GRAPH_REDIRECT_URI=https://devfocus.fly.dev/api/integrations/calendar/callback
